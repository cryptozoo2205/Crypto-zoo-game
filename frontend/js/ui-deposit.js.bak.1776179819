window.CryptoZoo = window.CryptoZoo || {};

CryptoZoo.uiDeposit = {
    selectedAmount: 1,
    activeDepositExpiresAt: 0,
    activeDepositCountdownInterval: null,

    getStaticDepositOptions() {
        return [1, 3, 5, 10];
    },

    getDepositGemsAmount(amount) {
        const serviceValue = Number(
            CryptoZoo.deposit?.getDepositGemsAmount?.(amount)
        );

        if (Number.isFinite(serviceValue) && serviceValue >= 0) {
            return serviceValue;
        }

        const safeAmount = Number(amount) || 0;

        if (safeAmount >= 10) return 150;
        if (safeAmount >= 5) return 70;
        if (safeAmount >= 3) return 35;
        if (safeAmount >= 1) return 10;

        return 0;
    },

    getDepositExpeditionBoostAmount(amount) {
        const serviceValue = Number(
            CryptoZoo.deposit?.getDepositExpeditionBoostAmount?.(amount)
        );

        if (Number.isFinite(serviceValue) && serviceValue >= 0) {
            return serviceValue;
        }

        const safeAmount = Number(amount) || 0;

        if (safeAmount >= 10) return 0.60;
        if (safeAmount >= 5) return 0.30;
        if (safeAmount >= 3) return 0.15;
        if (safeAmount >= 1) return 0.05;

        return 0;
    },

    getDepositOptions() {
        return this.getStaticDepositOptions().map((amount) => ({
            amount,
            gems: this.getDepositGemsAmount(amount),
            boost: this.getDepositExpeditionBoostAmount(amount)
        }));
    },

    getMount() {
        return document.getElementById("settingsDepositAmountOptions");
    },

    getLanguage() {
        return CryptoZoo.lang?.current || "en";
    },

    isPolish() {
        return this.getLanguage() === "pl";
    },

    t(plText, enText) {
        return this.isPolish() ? plText : enText;
    },

    formatBoost(boost) {
        return `+${Math.round((Number(boost) || 0) * 100)}% ${this.t("expedycja", "expedition")}`;
    },

    getBestValueAmount() {
        return 10;
    },

    ensureSelectedAmount() {
        const options = this.getStaticDepositOptions();
        if (!options.includes(Number(this.selectedAmount))) {
            this.selectedAmount = options[0];
        }
    },


    formatCountdownMs(ms) {
        const totalSeconds = Math.max(0, Math.ceil((Number(ms) || 0) / 1000));
        const minutes = Math.floor(totalSeconds / 60);
        const seconds = totalSeconds % 60;
        return `${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
    },

    getActiveDepositRemainingMs() {
        const expiresAt = Number(this.activeDepositExpiresAt || 0);
        if (!expiresAt) return 0;
        return Math.max(0, expiresAt - Date.now());
    },

    clearActiveDepositCountdown() {
        this.activeDepositExpiresAt = 0;
        if (this.activeDepositCountdownInterval) {
            clearInterval(this.activeDepositCountdownInterval);
            this.activeDepositCountdownInterval = null;
        }
        this.renderActiveDepositCountdownHint();
    },

    setActiveDepositCountdown(expiresAt) {
        const safeExpiresAt = Number(expiresAt || 0);
        if (!safeExpiresAt) {
            this.clearActiveDepositCountdown();
            return;
        }

        this.activeDepositExpiresAt = safeExpiresAt;

        if (this.activeDepositCountdownInterval) {
            clearInterval(this.activeDepositCountdownInterval);
            this.activeDepositCountdownInterval = null;
        }

        this.renderActiveDepositCountdownHint();

        this.activeDepositCountdownInterval = setInterval(() => {
            const remaining = this.getActiveDepositRemainingMs();
            if (remaining <= 0) {
                this.clearActiveDepositCountdown();
                return;
            }
            this.renderActiveDepositCountdownHint();
        }, 1000);
    },

    getCountdownHintHost() {
        const mount = this.getMount();
        if (!mount || !mount.parentNode) return null;

        let host = document.getElementById("settingsDepositCountdownHint");
        if (!host) {
            host = document.createElement("div");
            host.id = "settingsDepositCountdownHint";
            host.style.width = "100%";
            host.style.marginTop = "12px";
            mount.parentNode.insertBefore(host, mount.nextSibling);
        }

        return host;
    },

    renderActiveDepositCountdownHint() {
        const host = this.getCountdownHintHost();
        if (!host) return;

        const remainingMs = this.getActiveDepositRemainingMs();
        if (remainingMs <= 0) {
            host.innerHTML = "";
            return;
        }

        const label = this.t("Nowy depozyt za", "New deposit in");
        host.innerHTML = `
            <div style="
                width: 100%;
                padding: 12px 14px;
                border-radius: 14px;
                border: 1px solid rgba(255,255,255,0.10);
                background: rgba(255,255,255,0.04);
                color: #ffd76a;
                font-size: 14px;
                font-weight: 800;
                text-align: center;
                box-sizing: border-box;
            ">
                ${label} ${this.formatCountdownMs(remainingMs)}
            </div>
        `;
    },

    render() {
        const mount = this.getMount();
        if (!mount) return;

        this.ensureSelectedAmount();

        const options = this.getDepositOptions();

        mount.innerHTML = `
            <div style="display:flex; flex-wrap:wrap; gap:12px; width:100%;">
                ${options.map((opt) => {
                    const isSelected = Number(this.selectedAmount) === Number(opt.amount);
                    const isBestValue = Number(opt.amount) === Number(this.getBestValueAmount());

                    return `
                        <button
                            type="button"
                            data-deposit-amount="${opt.amount}"
                            style="
                                flex:1 1 calc(50% - 6px);
                                min-width:135px;
                                padding:14px;
                                border-radius:16px;
                                background:${isSelected
                                    ? "linear-gradient(145deg, rgba(52,211,153,0.20), rgba(255,255,255,0.05))"
                                    : "linear-gradient(145deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02))"};
                                border:${isSelected
                                    ? "2px solid #34d399"
                                    : "1px solid rgba(255,255,255,0.10)"};
                                box-shadow:${isSelected
                                    ? "0 0 0 1px rgba(52,211,153,0.18), 0 8px 22px rgba(0,0,0,0.28)"
                                    : "0 6px 18px rgba(0,0,0,0.25)"};
                                cursor:pointer;
                                text-align:left;
                                color:#ffffff;
                                transition:transform .15s ease, box-shadow .15s ease, border .15s ease;
                            "
                        >
                            <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:10px;">
                                <div style="font-size:17px; font-weight:900; line-height:1;">
                                    ${opt.amount} TON
                                </div>

                                ${isBestValue ? `
                                    <div style="
                                        font-size:11px;
                                        font-weight:900;
                                        color:#08130f;
                                        background:linear-gradient(180deg, #34d399 0%, #10b981 100%);
                                        padding:4px 8px;
                                        border-radius:999px;
                                        white-space:nowrap;
                                        box-shadow:0 4px 12px rgba(16,185,129,0.28);
                                    ">
                                        ${this.t("BEST", "BEST")}
                                    </div>
                                ` : ""}
                            </div>

                            <div style="margin-top:10px; font-size:13px; color:rgba(255,255,255,0.88); font-weight:700;">
                                💎 +${opt.gems} ${this.t("gems", "gems")}
                            </div>

                            <div style="margin-top:4px; font-size:13px; color:#4ade80; font-weight:700;">
                                ⚡ ${this.formatBoost(opt.boost)}
                            </div>
                        </button>
                    `;
                }).join("")}
            </div>
        `;

        mount.querySelectorAll("[data-deposit-amount]").forEach((btn) => {
            btn.onclick = () => {
                const amount = Number(btn.getAttribute("data-deposit-amount")) || 1;
                this.selectedAmount = amount;
                this.render();

                if (CryptoZoo.uiSettings) {
                    CryptoZoo.uiSettings.selectedDepositAmount = amount;
                }

                CryptoZoo.ui?.showToast?.(
                    this.t(`Wybrano ${amount} TON`, `${amount} TON selected`)
                );
            };
        });
    },

    async select(amount = null) {
        const finalAmount = Number(amount) || Number(this.selectedAmount) || 1;

        this.selectedAmount = finalAmount;

        if (CryptoZoo.uiSettings) {
            CryptoZoo.uiSettings.selectedDepositAmount = finalAmount;
        }

        try {
            const res = await CryptoZoo.api.request("/deposit/create", {
                method: "POST",
                body: JSON.stringify({
                    telegramId: CryptoZoo.api.getPlayerId(),
                    username: CryptoZoo.api.getUsername?.() || "",
                    amount: finalAmount
                })
            });

            if (res?.depositId || res?.paymentComment || res?.receiverAddress || res?.paymentData) {
                CryptoZoo.ui?.showToast?.(
                    this.t("Depozyt utworzony", "Deposit created")
                );
                CryptoZoo.ui?.renderDepositPayment?.(res);
                return true;
            }

            CryptoZoo.ui?.showToast?.(
                this.t("Nie udało się utworzyć depozytu", "Failed to create deposit")
            );
            return false;
        } catch (e) {
            console.error("Deposit create error:", e);

            const rawErrorMessage = String(e?.message || "");
            const jsonStart = rawErrorMessage.indexOf("{");
            let payload = null;

            if (jsonStart >= 0) {
                try {
                    payload = JSON.parse(rawErrorMessage.slice(jsonStart));
                } catch (_) {}
            }

            const activeDepositExpiresAt = Number(payload?.activeDeposit?.expiresAt || 0);
            if (activeDepositExpiresAt > Date.now()) {
                this.setActiveDepositCountdown(activeDepositExpiresAt);
                CryptoZoo.ui?.showToast?.(
                    this.t("Masz już aktywny depozyt", "You already have an active deposit")
                );
                return false;
            }

            CryptoZoo.ui?.showToast?.(
                this.t("Błąd tworzenia depozytu", "Deposit error")
            );
            return false;
        }
    },

    init() {
        this.ensureSelectedAmount();
        this.render();
    }
};