window.CryptoZoo = window.CryptoZoo || {};

CryptoZoo.boxes = {
    ensureState() {
        CryptoZoo.state = CryptoZoo.state || {};

        CryptoZoo.state.coins = Number(CryptoZoo.state.coins) || 0;
        CryptoZoo.state.gems = Number(CryptoZoo.state.gems) || 0;
        CryptoZoo.state.rewardBalance = Number(CryptoZoo.state.rewardBalance) || 0;

        if (!CryptoZoo.state.boxes || typeof CryptoZoo.state.boxes !== "object") {
            CryptoZoo.state.boxes = {
                common: 0,
                rare: 0,
                epic: 0,
                legendary: 0
            };
        }

        CryptoZoo.state.boxes.common = Number(CryptoZoo.state.boxes.common) || 0;
        CryptoZoo.state.boxes.rare = Number(CryptoZoo.state.boxes.rare) || 0;
        CryptoZoo.state.boxes.epic = Number(CryptoZoo.state.boxes.epic) || 0;
        CryptoZoo.state.boxes.legendary = Number(CryptoZoo.state.boxes.legendary) || 0;
    },

    saveLocalState() {
        try {
            localStorage.setItem("cryptozoo_save", JSON.stringify(CryptoZoo.state));
        } catch (error) {
            console.warn("Local box save error:", error);
        }
    },

    buy(type) {
        try {
            this.ensureState();

            const config =
                CryptoZoo.config &&
                CryptoZoo.config.boxes &&
                CryptoZoo.config.boxes[type]
                    ? CryptoZoo.config.boxes[type]
                    : null;

            CryptoZoo.ui?.showToast?.(`BUY start ${type}`);

            if (!config) {
                CryptoZoo.ui?.showToast?.("Błąd config boxa");
                return;
            }

            const buyCoins = Number(config.buyCoins) || 0;
            const buyGems = Number(config.buyGems) || 0;

            const coins = Number(CryptoZoo.state.coins) || 0;
            const gems = Number(CryptoZoo.state.gems) || 0;

            if (buyCoins > 0 && coins < buyCoins) {
                CryptoZoo.ui?.showToast?.("Za mało coins");
                return;
            }

            if (buyGems > 0 && gems < buyGems) {
                CryptoZoo.ui?.showToast?.("Za mało gems");
                return;
            }

            CryptoZoo.state.coins = coins - buyCoins;
            CryptoZoo.state.gems = gems - buyGems;
            CryptoZoo.state.boxes[type] = (Number(CryptoZoo.state.boxes[type]) || 0) + 1;

            this.saveLocalState();
            CryptoZoo.ui?.render?.();

            CryptoZoo.ui?.showToast?.(
                `BUY done ${type} | boxes=${CryptoZoo.state.boxes[type]}`
            );
        } catch (error) {
            console.error("Box buy error:", error);
            CryptoZoo.ui?.showToast?.("Błąd buy box");
        }
    },

    open(type) {
        try {
            this.ensureState();

            const count = Number(CryptoZoo.state.boxes[type]) || 0;

            CryptoZoo.ui?.showToast?.(`OPEN start ${type} | count=${count}`);

            if (count <= 0) {
                CryptoZoo.ui?.showToast?.("Brak boxa");
                return;
            }

            const config =
                CryptoZoo.config &&
                CryptoZoo.config.boxes &&
                CryptoZoo.config.boxes[type]
                    ? CryptoZoo.config.boxes[type]
                    : null;

            if (!config) {
                CryptoZoo.ui?.showToast?.("Błąd config boxa");
                return;
            }

            CryptoZoo.state.boxes[type] = count - 1;

            const coinMin = Number(config.coinMin) || 0;
            const coinMax = Number(config.coinMax) || 0;
            const gemsMin = Number(config.gemsMin) || 0;
            const gemsMax = Number(config.gemsMax) || 0;
            const rewardMax = Number(config.rewardMax) || 0;

            const coins = Math.floor(Math.random() * (coinMax - coinMin + 1)) + coinMin;
            const gems = Math.floor(Math.random() * (gemsMax - gemsMin + 1)) + gemsMin;
            const reward = rewardMax > 0 ? Number((Math.random() * rewardMax).toFixed(2)) : 0;

            CryptoZoo.state.coins += coins;
            CryptoZoo.state.gems += gems;
            CryptoZoo.state.rewardBalance += reward;

            this.saveLocalState();
            CryptoZoo.ui?.render?.();

            CryptoZoo.ui?.showToast?.(
                `OPEN done +${CryptoZoo.formatNumber(coins)} coins +${CryptoZoo.formatNumber(gems)} gems`
            );
        } catch (error) {
            console.error("Box open error:", error);
            CryptoZoo.ui?.showToast?.("Błąd open box");
        }
    }
};