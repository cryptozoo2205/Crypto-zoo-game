window.CryptoZoo = window.CryptoZoo || {};

CryptoZoo.boxes = {
    init() {
        const buttons = document.querySelectorAll("[data-box-type]");

        buttons.forEach((button) => {
            button.onclick = () => {
                const type = button.getAttribute("data-box-type");
                this.buy(type);
            };
        });
    },

    ensureState() {
        CryptoZoo.state = CryptoZoo.state || {};

        if (!CryptoZoo.state.boxes) {
            CryptoZoo.state.boxes = {
                common: 0,
                rare: 0,
                epic: 0,
                legendary: 0
            };
        }
    },

    // 🔥 NOWE: lepszy roll (bias do środka + lekkie szczęście)
    rollBetween(min, max, luckFactor = 1) {
        const r1 = Math.random();
        const r2 = Math.random();

        // bias do wyższych wartości przy luckFactor
        const mixed = (r1 + r2 * luckFactor) / (1 + luckFactor);

        return Math.floor(min + mixed * (max - min));
    },

    buy(type) {
        this.ensureState();

        const config = CryptoZoo.config?.boxes?.[type];
        if (!config) {
            CryptoZoo.ui?.showToast?.("Błąd config boxa");
            return;
        }

        const buyCoins = Number(config.buyCoins) || 0;
        const buyGems = Number(config.buyGems) || 0;

        if ((CryptoZoo.state.coins || 0) < buyCoins) {
            CryptoZoo.ui?.showToast?.("Za mało coins");
            return;
        }

        if ((CryptoZoo.state.gems || 0) < buyGems) {
            CryptoZoo.ui?.showToast?.("Za mało gems");
            return;
        }

        CryptoZoo.state.coins -= buyCoins;
        CryptoZoo.state.gems -= buyGems;
        CryptoZoo.state.boxes[type] = (CryptoZoo.state.boxes[type] || 0) + 1;

        CryptoZoo.api?.savePlayer?.();
        CryptoZoo.ui?.render?.();
        CryptoZoo.ui?.showToast?.("Kupiono box");
    },

    open(type) {
        this.ensureState();

        if ((CryptoZoo.state.boxes[type] || 0) <= 0) {
            CryptoZoo.ui?.showToast?.("Brak boxa");
            return;
        }

        const config = CryptoZoo.config?.boxes?.[type];
        if (!config) {
            CryptoZoo.ui?.showToast?.("Błąd config boxa");
            return;
        }

        CryptoZoo.state.boxes[type]--;

        const coinMin = Number(config.coinMin) || 0;
        const coinMax = Number(config.coinMax) || 0;
        const gemsMin = Number(config.gemsMin) || 0;
        const gemsMax = Number(config.gemsMax) || 0;
        const rewardMax = Number(config.rewardMax) || 0;

        // 🎯 różne "luck" zależnie od boxa
        const luckMap = {
            common: 0.8,
            rare: 1.0,
            epic: 1.2,
            legendary: 1.5
        };

        const luck = luckMap[type] || 1;

        const coins = this.rollBetween(coinMin, coinMax, luck);
        const gems = this.rollBetween(gemsMin, gemsMax, luck);

        let reward = 0;
        if (rewardMax > 0) {
            reward = Number((Math.random() * rewardMax * luck).toFixed(2));
        }

        // 🔥 BONUS ROLL (jackpot feel)
        let bonusCoins = 0;
        if (Math.random() < 0.08 * luck) {
            bonusCoins = Math.floor(coins * (0.5 + Math.random()));
        }

        CryptoZoo.state.coins += coins + bonusCoins;
        CryptoZoo.state.gems += gems;
        CryptoZoo.state.rewardBalance += reward;

        CryptoZoo.api?.savePlayer?.();
        CryptoZoo.ui?.render?.();

        const format = CryptoZoo.formatNumber || ((v) => String(v));

        CryptoZoo.ui?.showToast?.(
            "Box: +" +
            format(coins + bonusCoins) +
            " coins, +" +
            gems +
            " gems" +
            (reward > 0 ? ", +" + reward + " reward" : "") +
            (bonusCoins > 0 ? " 🎉 BONUS!" : "")
        );
    }
};